#!/bin/bash
# Non-interactive shell initialization (sourced via BASH_ENV)
# Ensures PATH, tool shims, and project venvs are available in
# non-interactive shells (e.g. Claude Code, scripts, CI)

# PATH and tool setup (mise, pyenv, nvm, etc.)
if [[ -r "$HOME/.bash.d/.bash_paths" ]]; then
    . "$HOME/.bash.d/.bash_paths"
fi

# Auto-activate project venv based on working directory
# Each command gets a fresh shell, so this re-evaluates every time
_dir="$PWD"
while [[ "$_dir" != "/" ]]; do
    if [[ -d "$_dir/.venv/uv-venv/bin" ]]; then
        export VIRTUAL_ENV="$_dir/.venv/uv-venv"
        export PATH="$VIRTUAL_ENV/bin:$PATH"
        break
    elif [[ -d "$_dir/.venv/bin" ]]; then
        export VIRTUAL_ENV="$_dir/.venv"
        export PATH="$VIRTUAL_ENV/bin:$PATH"
        break
    fi
    _dir=$(dirname "$_dir")
done
unset _dir
